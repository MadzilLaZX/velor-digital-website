# Copy this file to .env.local and fill in values when integrations are connected.

# Site
NEXT_PUBLIC_SITE_URL=https://velordigital.com

# Booking form submission (see TODO in src/components/sections/booking-form.tsx)
# n8n webhook that receives booking submissions and fans out to CRM/email/SMS
N8N_BOOKING_WEBHOOK_URL=

# Supabase (leads / CRM storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Transactional email (client confirmation + internal notification to hello@velordigital.com)
RESEND_API_KEY=

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
