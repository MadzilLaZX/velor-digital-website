# Copy this file to .env.local and fill in values when integrations are connected.

# Site
NEXT_PUBLIC_SITE_URL=https://velordigital.com

# --- Booking backend (n8n) ---------------------------------------------
# n8n webhook base URL that receives booking submissions and fans out to
# Calendar/Sheets/Telegram/Email. The three sub-paths (/availability,
# /strategy-call, /emergency) are appended automatically. See n8n/*.json.
N8N_BOOKING_WEBHOOK_URL=
# Shared secret used to HMAC-sign requests from this app to n8n, and for
# n8n to verify they weren't spoofed. Set the same value in both places.
N8N_WEBHOOK_SHARED_SECRET=

# --- Booking scheduling rules (all optional — sane defaults in booking-config.ts) ---
BOOKING_TIMEZONE=America/Toronto
STANDARD_MEETING_DURATION_MINUTES=60
STANDARD_MEETING_BUFFER_MINUTES=15
STANDARD_BOOKING_START_HOUR=9
STANDARD_BOOKING_END_HOUR=21
BOOKING_SLOT_INTERVAL_MINUTES=60
MINIMUM_BOOKING_NOTICE_HOURS=12
MAXIMUM_BOOKING_DAYS_AHEAD=60

EMERGENCY_REQUESTS_ENABLED=true
EMERGENCY_START_HOUR=8
EMERGENCY_END_HOUR=22
EMERGENCY_DURATION_MINUTES=60
EMERGENCY_AUTO_CONFIRM=false

# Supabase (leads / CRM storage) — optional, not required by the booking flow
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- The following are NOT used by this Next.js app. They belong on the ---
# --- n8n instance's own environment (docker-compose / hosting panel),   ---
# --- never in this repo or in Vercel. Listed here only for reference —  ---
# --- see docs/BOOKING_SYSTEM.md for the full n8n setup.                 ---
#   N8N_WEBHOOK_SHARED_SECRET   (must match the value above)
#   NODE_FUNCTION_ALLOW_BUILTIN=crypto
#   VELOR_STRATEGY_CALLS_CALENDAR_ID
#   VELOR_SPREADSHEET_ID
#   VELOR_TEAM_ATTENDEE_EMAILS
#   VELOR_NOTIFICATION_EMAILS
#   TELEGRAM_CHAT_ID
#   RESEND_API_KEY               (attached as an n8n credential, not env)
#   BOOKING_TIMEZONE / STANDARD_MEETING_DURATION_MINUTES / etc.
#     (mirror the values above so n8n's slot math matches the website's)
