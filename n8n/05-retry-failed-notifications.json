          "conditions": [
            {
              "leftValue": "={{ $('Merge Retry Results').item.json.newRetryCount }}",
              "rightValue": 5,
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
