      "parameters": {
        "chatId": "5038813723",
        "text": "=RETRY — Booking {{ $json['Booking ID'] }} — {{ $json['Full Name'] }} — {{ $json['Meeting Date'] }} {{ $json['Start Time'] }} ET",
        "additionalFields": {}
      },
      "credentials": {
        "telegramApi": {
          "id": "zztcwsaom20LpOV7",
          "name": "Velor - Telegram"
        }
      },
      "webhookId": "af942e28-2e78-4e0a-bddb-0958dff21aa4"
    },
