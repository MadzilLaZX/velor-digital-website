{
  "name": "Velor Booking - 05 Retry Failed Notifications",
  "nodes": [
    {
      "id": "schedule-trigger",
      "name": "Every 30 Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        -1200,
        0
      ],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 30
            }
          ]
        }
      }
    },
    {
      "id": "http-get-bookings",
      "name": "HTTP: Get All Bookings",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -960,
        0
      ],
      "parameters": {
        "method": "GET",
        "url": "https://sheets.googleapis.com/v4/spreadsheets/1UkvzpXxs0aYLs3Znxp5mVuV3jEJBM5iEo-jOQAEPHEY/values/Bookings!A2:BA100000",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleSheetsOAuth2Api"
      },
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "05GiWdmZswSbZZzW",
          "name": "Velor - Google Sheets"
        }
      }
    },
    {
      "id": "code-parse-rows",
      "name": "Parse Rows To Objects",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -840,
        0
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const headers = [\"Booking ID\",\"Submitted At\",\"Appointment Type\",\"Status\",\"Meeting Date\",\"Start Time\",\"End Time\",\"Time Zone\",\"Full Name\",\"Email\",\"Phone\",\"Normalized Phone\",\"Business Name\",\"Business Website\",\"Service Interested In\",\"Budget Range\",\"Project Details\",\"Where Did You Hear About Us?\",\"Lead Source Details\",\"Preferred Contact Method\",\"Additional Participants\",\"Agreement Accepted\",\"Agreement Version\",\"Agreement Timestamp\",\"Conflict Detected\",\"Calendar Event Created\",\"Calendar Event Link\",\"Google Meet Link\",\"Calendar Event ID\",\"Client Confirmation Sent\",\"Team Email Sent\",\"Telegram Notification Sent\",\"Rescheduled From\",\"Cancellation Reason\",\"Internal Notes\",\"Assigned To\",\"Last Updated At\",\"Updated By\",\"Submission Source\",\"UTM Source\",\"UTM Medium\",\"UTM Campaign\",\"UTM Content\",\"UTM Term\",\"Landing Page\",\"Referrer\",\"IP Address\",\"User Agent\",\"Automation Version\",\"Processing Error\",\"Submission ID (internal)\",\"Status Change Processed\",\"Retry Count\"];\nconst rows = $input.first().json.values || [];\nreturn rows.map((r, i) => {\n  const obj = {};\n  headers.forEach((h, idx) => { obj[h] = r[idx] !== undefined ? r[idx] : \"\"; });\n  obj.rowNumber = i + 2;\n  return { json: obj };\n});\n"
      }
    },
    {
      "id": "code-filter-failed",
      "name": "Filter Rows With Failed Notifications",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -720,
        0
      ],
      "notes": "Only retries the specific notification(s) that failed — never re-creates the Calendar event or Sheets row. Add a 'Retry Count' column beyond AX to cap attempts.",
      "parameters": {
        "language": "javaScript",
        "jsCode": "const MAX_RETRIES = 5;\nreturn $input.all().filter(item => {\n  const j = item.json;\n  const hasFailure = j['Client Confirmation Sent'] === 'No' || j['Team Email Sent'] === 'No' || j['Telegram Notification Sent'] === 'No';\n  const retries = Number(j['Retry Count'] || 0);\n  return hasFailure && retries < MAX_RETRIES;\n});\n"
      }
    },
    {
      "id": "if-telegram-failed",
      "name": "Telegram Failed?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        -480,
        -180
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "leftValue": "={{ $json['Telegram Notification Sent'] }}",
              "rightValue": "No",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "telegram-retry",
      "name": "Telegram: Retry Send",
      "type": "n8n-nodes-base.telegram",
