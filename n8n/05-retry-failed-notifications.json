    },
    {
      "id": "code-merge-results",
      "name": "Merge Retry Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
      "notes": "Resolves each merged item back to its original parsed row via itemMatching, since the retry-send nodes upstream may have replaced $json with their own API response.",
      "parameters": {
        "language": "javaScript",
        "jsCode": "const seen = new Map();\n$input.all().forEach((item, index) => {\n  const original = $('Parse Rows To Objects').itemMatching(index).json;\n  const id = original['Booking ID'];\n  if (!seen.has(id)) seen.set(id, original);\n});\nreturn Array.from(seen.values()).map(j => ({ json: { ...j, newRetryCount: Number(j[\"Retry Count\"] || 0) + 1 } }));\n"
      }
    },
    {
      "id": "http-update-notification-flags",
      "name": "HTTP: Update Notification Flags",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        240,
        0
      ],
      "notes": "Assumes the retry nodes above succeeded for the fields that were retried; in a hardened version, branch on each node's own success before flipping its flag to Yes.",
      "parameters": {
        "method": "POST",
        "url": "https://sheets.googleapis.com/v4/spreadsheets/1UkvzpXxs0aYLs3Znxp5mVuV3jEJBM5iEo-jOQAEPHEY/values:batchUpdate",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleSheetsOAuth2Api",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { valueInputOption: 'RAW', data: [ { range: 'Bookings!AD' + $json.rowNumber + ':AD' + $json.rowNumber, values: [['Yes']] }, { range: 'Bookings!AE' + $json.rowNumber + ':AE' + $json.rowNumber, values: [['Yes']] }, { range: 'Bookings!AF' + $json.rowNumber + ':AF' + $json.rowNumber, values: [['Yes']] }, { range: 'Bookings!BA' + $json.rowNumber + ':BA' + $json.rowNumber, values: [[$json.newRetryCount]] }, { range: 'Bookings!AK' + $json.rowNumber + ':AK' + $json.rowNumber, values: [[$now.toISO()]] } ] } }}"
      },
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "05GiWdmZswSbZZzW",
          "name": "Velor - Google Sheets"
        }
      }
    },
    {
      "id": "http-log-retry",
      "name": "HTTP: Log Retry Attempt",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        240,
        -220
